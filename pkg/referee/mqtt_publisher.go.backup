				fmt.Println("用法: total <总局数>")
				continue
			}
			total, err := strconv.ParseUint(parts[1], 10, 32)
			if err != nil {
				fmt.Printf("无效的总局数: %s\n", parts[1])
				continue
			}
			gs.setTotalRounds(uint32(total))

		case "stage":
