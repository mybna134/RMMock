		case "rfid":
			if len(parts) < 2 {
				fmt.Println("用法: rfid <状态>")
				continue
			}
			status, err := strconv.ParseUint(parts[1], 10, 32)
			if err != nil {
				fmt.Printf("无效的状态值: %s\n", parts[1])
				continue
