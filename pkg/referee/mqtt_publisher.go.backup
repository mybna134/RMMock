			if err != nil {
				fmt.Printf("无效的秒数: %s\n", parts[1])
				continue
			}
			if seconds == 0 {
				fmt.Println("秒数必须大于0")
				continue
			}
			gs.startOutOfCombatCountdown(uint32(seconds))
			fmt.Printf("✓ 已开始脱离战斗倒计时: %d秒\n", seconds)

		case "stopoutcombat":
			gs.stopOutOfCombatCountdown()
			fmt.Println("✓ 已停止脱离战斗倒计时")

